DATABASE_URL=postgres://postgres@127.0.0.1:5432/recette_app
JWT_SECRET=change-me-in-production
PORT=3000
# Laisser vide en dev local (CORS ouvert à tout, utile pour tester depuis un
# mobile sur le même réseau). En prod, mettre l'URL exacte du frontend
# déployé (ex. https://mon-app.vercel.app) pour restreindre les requêtes.
FRONTEND_URL=
# Mot de passe oublié : sans clé, l'e-mail n'est pas envoyé (juste journalisé)
# mais le reste du flux fonctionne quand même. Nécessite un compte Resend et
# un nom de domaine vérifié pour envoyer à des destinataires autres que vous.
RESEND_API_KEY=
MAIL_FROM=onboarding@resend.dev
# Analyse des ingrédients en texte libre : sans clé, on retombe sur la seule
# similarité de nom (pg_trgm) pour choisir l'aliment le plus proche. Avec une
# clé, Claude choisit parmi les candidats réels de la base — jamais de macro
# inventée, seulement un meilleur choix parmi des entrées CIQUAL existantes.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
